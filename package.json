{
  "name": "dashboard",
  "version": "0.0.12",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "dev": "bash scripts/dev.sh",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "coverage:update": "ng test --no-watch --coverage && node scripts/coverage-report.mjs",
    "deploy": "bash deploy.sh",
    "db:migrate": "bash ../postgres/migrate.sh",
    "db:migrate:live": "bash ../postgres/migrate.sh --live",
    "db:pg:generate": "node --env-file=.env node_modules/.bin/drizzle-kit generate --config db/drizzle.config.ts",
    "db:pg:migrate": "node --env-file=.env node_modules/.bin/drizzle-kit migrate --config db/drizzle.config.ts",
    "db:pg:studio": "node --env-file=.env node_modules/.bin/drizzle-kit studio --config db/drizzle.config.ts",
    "db:pg:push": "node --env-file=.env node_modules/.bin/drizzle-kit push --config db/drizzle.config.ts",
    "db:pg:etl": "node --env-file=.env --import tsx scripts/etl/sqlite-to-postgres.ts",
    "api": "node --env-file=.env --import tsx --watch api/server.ts",
    "build:api": "tsc -p tsconfig.api.json",
    "start:api": "node dist-api/api/server.js",
    "release": "standard-version",
    "release:minor": "standard-version --release-as minor",
    "release:major": "standard-version --release-as major",
    "release:patch": "standard-version --release-as patch"
  },
  "private": true,
  "packageManager": "npm@11.9.0",
  "dependencies": {
    "@angular/cdk": "21.2.8",
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "@hono/node-server": "2.0.0",
    "@hono/swagger-ui": "0.6.1",
    "@hono/zod-openapi": "1.2.4",
    "drizzle-orm": "0.45.2",
    "hono": "4.12.15",
    "postgres": "3.4.9",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@angular/build": "^21.2.7",
    "@angular/cli": "^21.2.7",
    "@angular/compiler-cli": "^21.2.0",
    "@playwright/test": "1.59.1",
    "@types/better-sqlite3": "7.6.13",
    "@vitest/coverage-v8": "4.1.5",
    "better-sqlite3": "12.9.0",
    "dotenv": "17.4.2",
    "drizzle-kit": "0.31.10",
    "jsdom": "^28.0.0",
    "prettier": "^3.8.1",
    "standard-version": "9.5.0",
    "tsx": "4.21.0",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  }
}
